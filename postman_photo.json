  },
  "item": [
    {
      "name": "Body Profile",
      "item": [
        {
          "name": "Create or Update Body Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/photo-tryon/body-profile?user_id=1",
              "host": ["{{base_url}}"],
              "path": ["photo-tryon", "body-profile"],
              "query": [
                {
                  "key": "user_id",
                  "value": "1"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"height\": 170.0,\n  \"weight\": 65.0,\n  \"chest\": 88.0,\n  \"waist\": 72.0,\n  \"hip\": 94.0,\n  \"shoulder\": 40.0,\n  \"arm_length\": 57.0,\n  \"inseam\": 76.0,\n  \"gender\": \"neutral\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        }
      ]
    },
    {
