            ],
            "url": {
              "raw": "{{base_url}}/photo-tryon/tryon?user_id=1",
              "host": ["{{base_url}}"],
              "path": ["photo-tryon", "tryon"],
              "query": [
                {
                  "key": "user_id",
                  "value": "1"
                }
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"avatar_id\": 1,\n  \"garment_id\": 1,\n  \"selected_size\": \"M\"\n}",
              "options": {
