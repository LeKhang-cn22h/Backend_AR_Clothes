              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          }
        },
        {
          "name": "Get Avatar Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/photo-tryon/avatar/1?user_id=1",
              "host": ["{{base_url}}"],
              "path": ["photo-tryon", "avatar", "1"],
              "query": [
                {
                  "key": "user_id",
                  "value": "1"
                }
              ]
            }
          }
        }
      ]
    },
    {
